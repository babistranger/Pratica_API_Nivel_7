const { Router } = require('express');
const routes = Router();

// Importa os controllers
const moviesController = require('../controllers/moviesController.js');

// Rota de health check
routes.get('/health', moviesController.HealthCheck);

// Criando as rotas de filmes (CRUD)
routes.get('/filmes', moviesController.listarFilmes);
routes.get('/filmes/:id', moviesController.buscarFilmePorId);
routes.post('/filmes', moviesController.criarFilme);
routes.put('/filmes/:id', moviesController.atualizarFilme);
routes.delete('/filmes/:id', moviesController.deletarFilme);

module.exports = routes;